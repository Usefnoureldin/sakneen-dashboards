# Database
DATABASE_URL=postgres://sakneen:sakneen@localhost:5432/sakneen_dashboards

# NextAuth (Auth.js v5). Generate with: openssl rand -base64 32
AUTH_SECRET=replace_me
# Required so NextAuth accepts non-localhost hosts in dev (nip.io subdomains)
AUTH_TRUST_HOST=true

# Storage
# Local dev: ./uploads — production (Railway): /data/uploads (mounted volume)
UPLOADS_DIR=./uploads
# 10MB cap on Excel uploads (per docs/03 security baseline)
MAX_UPLOAD_BYTES=10485760

# Email (Resend) - filled in later
RESEND_API_KEY=
EMAIL_FROM=
